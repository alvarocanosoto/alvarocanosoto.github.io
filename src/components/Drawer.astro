---
import { SITE, LINKS } from "@consts"
import { cn } from "@lib/utils"
import { getLocalizedPath } from "@i18n/ui"

const { pathname } = Astro.url
const isSpanish = pathname.startsWith("/es")
const strippedPathname = isSpanish ? pathname.replace(/^\/es/, "") || "/" : pathname
const subpath = strippedPathname.match(/[^/]+/g)
const langPrefix = isSpanish ? "/es" : ""
const langToggleHref = getLocalizedPath(pathname, isSpanish ? "en" : "es")
const langToggleLabel = isSpanish ? "EN" : "ES"
---

<div id="drawer" class="fixed inset-0 h-0 z-40 overflow-hidden flex flex-col items-center justify-center md:hidden bg-neutral-100 dark:bg-neutral-900 transition-[height] duration-300 ease-in-out">
  <nav class="flex flex-col items-center space-y-2">
    {LINKS.map((LINK) => (
      <a
        href={`${langPrefix}${LINK.HREF}`}
        class={cn(
          "flex items-center justify-center px-3 py-1 rounded-full",
          "text-current hover:text-black dark:hover:text-white",
          "hover:bg-black/5 dark:hover:bg-white/20",
          "transition-colors duration-300 ease-in-out",
          strippedPathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF
            ? "pointer-events-none bg-black dark:bg-white text-white dark:text-black"
            : ""
        )}
      >
        {LINK.TEXT}
      </a>
    ))}
  </nav>

  <div class="flex gap-1 mt-5">

    <!-- Language toggle -->
    <a
      href={langToggleHref}
      aria-label={`Switch to ${isSpanish ? "English" : "Spanish"}`}
      class="h-9 rounded-full px-3 flex items-center justify-center bg-transparent hover:bg-black/5 dark:hover:bg-white/20 text-current hover:text-black dark:hover:text-white border border-black/10 dark:border-white/25 text-sm font-semibold transition-colors duration-300 ease-in-out"
    >
      {langToggleLabel}
    </a>

    <!-- Search -->
    <a
      href={`${langPrefix}/search`}
      aria-label={`Search projects on ${SITE.TITLE}`}
      class={cn(
        "size-9 rounded-full p-2 items-center justify-center",
        "bg-transparent hover:bg-black/5 dark:hover:bg-white/20",
        "stroke-current hover:stroke-black hover:dark:stroke-white",
        "border border-black/10 dark:border-white/25",
        "transition-colors duration-300 ease-in-out",
        strippedPathname === "/search" ? "pointer-events-none bg-black dark:bg-white text-white dark:text-black" : ""
      )}
    >
      <svg class="size-full">
        <use href="/ui.svg#search"></use>
      </svg>
    </a>

    <!-- Theme toggle -->
    <button
      id="drawer-theme-button"
      aria-label="Toggle light and dark theme"
      class="size-9 rounded-full p-2 items-center justify-center bg-transparent hover:bg-black/5 dark:hover:bg-white/20 stroke-current hover:stroke-black hover:dark:stroke-white border border-black/10 dark:border-white/25 transition-colors duration-300 ease-in-out"
    >
      <svg class="block dark:hidden size-full">
        <use href="/ui.svg#sun"></use>
      </svg>
      <svg class="hidden dark:block size-full">
        <use href="/ui.svg#moon"></use>
      </svg>
    </button>

  </div>
</div>

<style>
  #drawer.open {
    @apply h-full;
  }
</style>
